    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.0.1",
    "@types/mailparser": "^3.4.5",
    "@types/node": "^20",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.17",
    "@types/react": "19.2.3",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^4.3.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "jsdom": "^25.0.1",
    "postcss": "^8",
    "prettier": "^3.3.3",
    "tailwindcss": "^4.1.4",
