# =============================================================================
# home-os — variables de entorno (EJEMPLO)
# Copiar a .env.local (dev) y configurar en Dokploy (prod). NUNCA commitear .env*.
# =============================================================================

# --- App ---------------------------------------------------------------------
APP_URL="http://localhost:3000"
# Secreto para proteger los endpoints /api/cron/* (genera uno aleatorio largo)
CRON_SECRET=""
# Frecuencia del sync en el worker (cron de 5 campos). Por defecto cada 15 min.
SYNC_CRON="*/15 * * * *"

# --- Supabase ----------------------------------------------------------------
# Panel del proyecto > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""        # solo servidor / worker — NUNCA al cliente
SUPABASE_DB_URL=""                   # cadena de conexión Postgres (migraciones)

# --- Notion ------------------------------------------------------------------
# notion.so/my-integrations > crea integración interna > copia el token
# Comparte CADA base de datos con la integración (••• > Connections).
NOTION_API_KEY=""
# IDs de las bases de finanzas (DBs dentro de la página "Finances").
# Tienen valor por defecto en src/lib/notion/schema.ts; solo hace falta
# definirlos aquí si quieres sobreescribirlos.
NOTION_DB_PRESUPUESTO_ID="2bb46da3a1d4801880c4cbc5c07e1a39"
NOTION_DB_DEUDAS_ID="2fb46da3a1d480538d51c44804e18bb1"
# IDs de otras DBs (se rellenan al implementar M2/M4).
# NOTION_DB_VIAJES_ID=""
# NOTION_DB_EVENTOS_ID=""
# NOTION_DB_CONTEXTO_ID=""
# Secreto para validar los webhooks entrantes de Notion (sync híbrido)
NOTION_WEBHOOK_SECRET=""

# --- Google (Gmail API + Calendar) — OAuth -----------------------------------
# Google Cloud Console > APIs & Services > Credentials > OAuth client (Web)
# Scopes: gmail.readonly, calendar.readonly (o calendar)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3000/api/auth/google/callback"
# Los refresh_token por cuenta NO van aquí: se guardan cifrados en Supabase (ver M3).

# --- Correo IMAP (dominio propio / otros proveedores) ------------------------
# Plantilla para UNA cuenta; el resto se gestionan en la tabla `email_accounts`.
# Las credenciales reales se guardan cifradas en Supabase, no en texto plano.
IMAP_EXAMPLE_HOST="imap.tudominio.com"
IMAP_EXAMPLE_PORT="993"
IMAP_EXAMPLE_USER=""
IMAP_EXAMPLE_PASSWORD=""             # app-password, no la contraseña principal

# --- Notificaciones salientes (nodemailer / SMTP) ----------------------------
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="home-os <no-reply@tudominio.com>"

# --- Cifrado de credenciales de cuentas en BD --------------------------------
# Clave de 32 bytes en base64 para cifrar tokens/passwords de cuentas (AES-256-GCM).
ACCOUNT_ENCRYPTION_KEY=""

# --- IA de runtime: Claude Code headless (suscripción, SIN API key) ----------
# El runner invoca Claude Code en modo headless autenticado por tu suscripción.
CLAUDE_CLI_PATH="claude"             # binario de Claude Code en el PATH del runner
CLAUDE_WORKDIR="./worker/agent"      # dir de trabajo del agente headless
# NO se define ANTHROPIC_API_KEY: la IA de runtime usa la suscripción vía Claude Code.
# Si en el futuro se quisiera robustez 24/7 con API key, se añadiría aquí y se
# cambiaría SOLO el runner (el resto del sistema es agnóstico).
